[include]
  # For username / creds / and machine specific setup
  path = ~/.gitconfig.local

[color]
  ui = auto
[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green
[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold
[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[user]
  email = eloisant@gmail.com
  name = Erwan Loisant
[push]
  default = matching
[core]
  excludesfile = /Users/elo/.gitignore_global
[alias]
  lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%C(bold blue)<%an>%Creset' --abbrev-commit
[filter "media"]
  required = true
  clean = git media clean %f
  smudge = git media smudge %f
